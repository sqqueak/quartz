---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: string;
}

const { src, alt, caption, width = '100%' } = Astro.props;
---

<figure class="blog-image" style={`--img-width: ${width};`}>
  <img src={src} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .blog-image {
    width: var(--img-width, 100%);
    /* Allow oversize widths (e.g. 120%) at wide viewports, but shrink
       to fit the viewport (minus 1rem of breathing room each side)
       when the window is too narrow to display the configured size. */
    max-width: calc(100vw - 2rem);
    margin: 1.75rem 0;
    display: block;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .blog-image img {
    display: block;
    width: 100%;
    height: auto;
    cursor: zoom-in;
  }

  .blog-image figcaption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-secondary-light);
    font-style: italic;
  }

  :global(.dark) .blog-image figcaption {
    color: var(--color-secondary-dark);
  }

  :global(.lightbox-overlay) {
    position: fixed;
    inset: 0;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    cursor: zoom-out;
    animation: lightbox-fade 0.15s ease-out;
  }

  :global(.lightbox-box) {
    background: var(--color-background-light);
    padding: 0.75rem;
    border-radius: 0.25rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.35);
    max-width: 98vw;
    max-height: 98vh;
    display: flex;
  }

  :global(.dark .lightbox-box) {
    background: var(--color-background-dark);
  }

  :global(.lightbox-overlay img) {
    display: block;
    object-fit: contain;
    /* Width is set inline to naturalWidth * ZOOM_FACTOR;
       these caps keep huge images on-screen. */
    max-width: calc(98vw - 1.5rem);
    max-height: calc(98vh - 1.5rem);
    height: auto;
  }

  @keyframes lightbox-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>

<script>
  const ZOOM_FACTOR = 1.5;

  function openLightbox(src: string, alt: string, naturalWidth: number) {
    const existing = document.querySelector('.lightbox-overlay');
    if (existing) existing.remove();

    const overlay = document.createElement('div');
    overlay.className = 'lightbox-overlay';
    overlay.setAttribute('role', 'dialog');
    overlay.setAttribute('aria-modal', 'true');
    overlay.setAttribute('aria-label', alt || 'Enlarged image');

    const box = document.createElement('div');
    box.className = 'lightbox-box';

    const img = document.createElement('img');
    img.src = src;
    img.alt = alt;
    if (naturalWidth > 0) {
      img.style.width = `${naturalWidth * ZOOM_FACTOR}px`;
    }

    box.appendChild(img);
    overlay.appendChild(box);

    const close = () => {
      overlay.remove();
      document.removeEventListener('keydown', onKey);
      document.body.style.overflow = '';
    };
    const onKey = (e: KeyboardEvent) => {
      if (e.key === 'Escape') close();
    };

    overlay.addEventListener('click', close);
    document.addEventListener('keydown', onKey);
    document.body.style.overflow = 'hidden';
    document.body.appendChild(overlay);
  }

  function setupLightbox() {
    document.querySelectorAll<HTMLImageElement>('.blog-image img').forEach((img) => {
      if (img.dataset.lightboxBound === 'true') return;
      img.dataset.lightboxBound = 'true';
      img.addEventListener('click', () =>
        openLightbox(img.src, img.alt, img.naturalWidth)
      );
    });
  }

  setupLightbox();
  document.addEventListener('astro:page-load', setupLightbox);
</script>

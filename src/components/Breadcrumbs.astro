---
interface Props {
  items: Array<{ label: string; href?: string }>;
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm" style="line-height: 1; color: var(--text-secondary);">
  <ol class="flex items-baseline gap-1" style="margin: 0; padding: 0; list-style: none;">
    {items.map((item, index) => (
      <li class="flex items-baseline gap-1" style="margin: 0; padding: 0;">
        {item.href ? (
          <a href={item.href} class="link">{item.label}</a>
        ) : (
          <span style="color: var(--text-secondary);">{item.label}</span>
        )}
        <span style="color: var(--text-secondary);">/</span>
        {index < items.length - 1 && <>{' '}</>}
      </li>
    ))}
  </ol>
</nav>

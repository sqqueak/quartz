---
interface Props {
  id: number | string;
}

const { id } = Astro.props;
---

<sup class="sidenote-ref" id={`sidenote-ref-${id}`}>{id}</sup><span class="sidenote" id={`sidenote-${id}`} data-id={String(id)}><sup class="sidenote-num">{id}</sup> <span class="sidenote-body"><slot /></span></span>

<style>
  .sidenote-ref {
    font-size: 0.7em;
    color: var(--color-accent-light);
    font-weight: 600;
    line-height: 0;
    vertical-align: baseline;
    position: relative;
    top: -0.7em;
    left: 0em;
  }

  :global(.dark) .sidenote-ref {
    color: var(--color-accent-dark);
  }

  /* Hidden on narrow screens — JS creates footnotes instead */
  .sidenote {
    display: none;
  }

  /* Wide screens: float to right margin */
  @media (min-width: 1100px) {
    .sidenote {
      display: block;
      float: right;
      clear: right;
      margin-right: -16.5rem;
      margin-top: 0.1rem;
      width: 14rem;
      font-size: 0.8rem;
      line-height: 1.4;
      color: var(--color-secondary-light);
      padding-left: 0.75rem;
      border-left: 2px solid var(--color-surface-light);
    }

    :global(.dark) .sidenote {
      color: var(--color-secondary-dark);
      border-left-color: var(--color-surface-dark);
    }
  }

  .sidenote-num {
    font-size: 0.7em;
    color: var(--color-accent-light);
    font-weight: 600;
    line-height: 0;
    vertical-align: super;
  }

  :global(.dark) .sidenote-num {
    color: var(--color-accent-dark);
  }
</style>

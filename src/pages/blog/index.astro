---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

// Get all blog posts, sorted by date
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="emilyyao.me | Blog" description="asdfasdf">
  <article class="prose-blog">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-1 font-serif leading-tight">Blog</h1>
      <div style="margin-top: -0.7rem; margin-bottom: 0.3rem;">
        <Breadcrumbs items={[
          { label: '~', href: '/' },
          { label: 'Blog' }
        ]} />
      </div>
    </header>
  </article>

  <div>
    {posts.map((post) => (
      <BlogPostCard
        slug={post.id}
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
      />
    ))}
  </div>

  {posts.length === 0 && (
    <p class="text-secondary-light dark:text-secondary-dark">
      No posts yet. Check back soon!
    </p>
  )}
</BaseLayout>
